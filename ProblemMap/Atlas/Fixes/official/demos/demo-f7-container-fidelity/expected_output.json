    ],
    "must_clarify": [
      "what was structurally missing in the baseline shell",
      "why the baseline descriptor was too weak for the task",
      "how the tightened container preserves the required distinctions"
    ],
    "container_quality_target": "formal_container_adequacy_restored_for_minimal_case"
  },
  "expected_route_explanation_contract": {
    "why_primary_not_secondary_must_express": [
      "the shell carrying the answer is too weak to preserve the intended structure",
      "container fidelity fails before reasoning progression becomes the primary repair target"
    ],
    "must_not_reduce_case_to": [
      "generic logic failure only",
      "generic weak reasoning only",
      "generic bad formatting only"
    ]
  },
  "expected_first_repair_move_contract": {
    "must_include_repair_moves": [
      "descriptor_fidelity_audit",
      "formal_adequacy_validation",
      "container_tightening",
      "structure_preservation_check",
      "reassess_reasoning_after_container_repair"
    ],
    "must_not_start_with": [
      "generic_reason_more_carefully_prompt",
      "longer_chain_of_thought",
      "retry_with_same_weak_shell",
      "more_examples_without_container_constraints"
    ]
  },
  "expected_before_after_contract": {
    "before_container_state": "leaky_and_underconstrained",
    "after_container_state": "tightened_and_task_adequate",
    "before_operator_position": "may_blame_reasoning_without_seeing_that_the_form_is_failing_first",
    "after_operator_position": "can_identify_that_the_shell_holds_and_only_then_reassess_remaining_reasoning_pressure",
    "required_change": "the repaired state must shift from partly correct content inside a broken shell to a structurally trustworthy answer inside a valid carrier"
  },
  "expected_teaching_contract": {
    "core_lesson": "If the box carrying the structure is weak, repair the box first.",
    "reader_should_learn": [
